# Database
DATABASE_URL="postgresql://flexdocs:flexdocs@localhost:5432/flexdocs"

# NextAuth
NEXTAUTH_SECRET="generate-a-strong-secret-here"
NEXTAUTH_URL="https://docs.example.com"

# Encryption key (generate with: openssl rand -hex 32)
ENCRYPTION_KEY="generate-a-strong-key-here"

# Redis
REDIS_URL="redis://localhost:6379"

# SMTP (for email notifications)
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="FlexDocs <noreply@flexdocs.local>"
SMTP_SECURE=false

# Logging
LOG_LEVEL="info"

# Backup
BACKUP_DIR="./backups"
BACKUP_RETENTION_DAYS=30

# PocketID (optional - leave empty to disable passkey auth)
POCKETID_CLIENT_ID=""
POCKETID_CLIENT_SECRET=""
POCKETID_ISSUER=""

# Database password (for docker-compose)
DB_PASSWORD="change-this-password"
